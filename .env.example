# SQLite is the default and needs no setup. Override to point at Postgres, etc.
DATABASE_URL=sqlite:///./poligrapher.db
HOST=0.0.0.0
PORT=8000
# Set RELOAD=true for backend auto-reload during development (off by default).
RELOAD=false
APP_ENV=development
# local (default) or azure. Local files are durable only for development.
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=poligrapher
TEMP_WORKSPACE_ROOT=
ARTIFACT_RETENTION_DAYS=90
SCHEDULER_ENABLED=true
# Optional anti-bot fallbacks. Prefer separate credentials over embedding them
# in CRAWL_PROXY. Leave unset to avoid third-party proxy charges.
CRAWL_PROXY=
CRAWL_PROXY_USERNAME=
CRAWL_PROXY_PASSWORD=
# fallback tries direct access first; always spends proxy bandwidth on every
# eligible request; off disables proxy use without deleting the secret.
CRAWL_PROXY_MODE=fallback
# URL template accepts {key} and {url}, e.g. an existing unblocker API account.
SCRAPE_API_URL=
SCRAPE_API_KEY=
# Required to download private raw artifact archives through the API.
EXPORT_TOKEN=
